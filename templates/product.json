        "custom_j7fVDd": {
          "type": "custom",
          "settings": {
            "code": "<div class=\"product-block\">\n  <div style=\"\n    background-color:#f5eee8;\n    border:1px solid #e0d7d0;\n    border-radius:6px;\n    padding:15px;\n    margin-top:12px;\n    font-size:14px;\n    line-height:1.5;\n    color:#b21e1e;\n    font-weight:500;\n  \">\n    <strong style=\"color:#b21e1e;\">\n      UPDATE ZOMERUITVERKOOP:\n    </strong>\n    Vanwege de grote vraag tijdens onze Zomeruitverkoop zijn er nog maar enkele stuks beschikbaar.\n    Zolang u nog op\n    <strong style=\"color:#b21e1e;\">'Toevoegen aan winkelwagen'</strong>\n    kunt klikken, is het product nog op voorraad.\n  </div>\n</div>\n\n<div class=\"product-info__liquid\">\n\n<style>\n  .shipping-bar {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    background: #f7f7f7;\n    border-radius: 12px;\n    padding: 6px 10px;\n    font-family: sans-serif;\n    gap: 10px;\n    font-size: 11px;\n    white-space: nowrap;\n    overflow: hidden;\n    margin-top: -10px;\n  }\n\n  .shipping-left,\n  .shipping-right {\n    display: flex;\n    align-items: center;\n    gap: 4px;\n    min-width: 0;\n  }\n\n  .shipping-text {\n    overflow: hidden;\n    text-overflow: ellipsis;\n    white-space: nowrap;\n  }\n\n  @media (max-width: 400px) {\n    .shipping-bar {\n      font-size: 9px;\n      padding: 5px 8px;\n    }\n  }\n\n  @media (max-width: 330px) {\n    .shipping-bar {\n      font-size: 8px;\n    }\n  }\n\n  @media (max-width: 290px) {\n    .shipping-bar {\n      font-size: 7px;\n    }\n  }\n</style>\n\n<div class=\"shipping-bar\">\n\n  <!-- LINKERKANT -->\n  <div class=\"shipping-left\">\n    <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"8\" height=\"8\" viewBox=\"0 0 12 13\">\n      <circle cx=\"6\" cy=\"6.5\" r=\"6\" fill=\"#137333\"></circle>\n    </svg>\n\n    <div class=\"shipping-text\" style=\"font-weight: 500;\">\n      Verzonden op\n      <span id=\"shipping-date\" style=\"font-weight: bold;\"></span>\n    </div>\n  </div>\n\n  <!-- RECHTERKANT -->\n  <div class=\"shipping-right\">\n    <img src=\"https://flagcdn.com/w20/nl.png\" alt=\"NL\" style=\"width: 14px; height: auto;\">\n    <div class=\"shipping-text\">\n      <span style=\"font-weight: bold;\">GRATIS PostNL verzending</span>\n    </div>\n  </div>\n\n</div>\n\n</div>\n\n<script>\n  (function () {\n    const daysNL = [\n      \"zondag\",\n      \"maandag\",\n      \"dinsdag\",\n      \"woensdag\",\n      \"donderdag\",\n      \"vrijdag\",\n      \"zaterdag\"\n    ];\n\n    const monthsNL = [\n      \"januari\",\n      \"februari\",\n      \"maart\",\n      \"april\",\n      \"mei\",\n      \"juni\",\n      \"juli\",\n      \"augustus\",\n      \"september\",\n      \"oktober\",\n      \"november\",\n      \"december\"\n    ];\n\n    const tomorrow = new Date();\n    tomorrow.setDate(tomorrow.getDate() + 1);\n\n    const dayName = daysNL[tomorrow.getDay()];\n    const dayNumber = tomorrow.getDate();\n    const monthName = monthsNL[tomorrow.getMonth()];\n\n    const el = document.getElementById(\"shipping-date\");\n    if (el) {\n      el.textContent = `${dayName} ${dayNumber} ${monthName}`;\n    }\n  })();\n</script>"
          }
